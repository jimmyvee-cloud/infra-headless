# Copy to aws-credentials.env next to docker-compose.yml (required for `docker compose up api`).
# Never commit aws-credentials.env — it is in .gitignore.
#
# Fill in keys for local/dev, OR leave blank and use the host ~/.aws mount in docker-compose.yml,
# OR `touch aws-credentials.env` if the host/instance supplies credentials (e.g. EC2 instance profile + IMDS).
#
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only when using temporary credentials
AWS_REGION=us-east-1
