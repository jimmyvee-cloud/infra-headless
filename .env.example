# Copy to `.env` next to docker-compose.yml (required). Gitignored — never commit with real keys.
#
# After editing: docker compose up -d --force-recreate api
#
# You cannot `docker exec` and `export` keys into a running API — uvicorn was already started.
# Edit this file and recreate the container instead.
#
WEB_HOST_PORT=5174

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Omit AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY if you rely only on the host ~/.aws mount.

# Optional: Docker `web` service only — SPA uses bundled pages only (no /delivery HTTP calls).
# VITE_STATIC_DELIVERY=true
