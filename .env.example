# Copy to `.env` in this folder (gitignored). Compose uses it for variable substitution
# and also passes AWS variables through to the `api` container (see docker-compose.yml env_file).
#
# If you prefer a separate file, use aws-credentials.env instead (see aws-credentials.env.example).

# WEB_HOST_PORT=5174

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
